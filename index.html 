<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criador de GIF Profissional</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        body {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            padding: 20px;
            min-height: 100vh;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }
        h1 {
            text-align: center;
            color: #1e3c72;
            margin-bottom: 10px;
            font-size: 26px;
        }
        .subtitulo {
            text-align: center;
            color: #666;
            font-size: 14px;
            margin-bottom: 20px;
        }
        .aviso {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            color: #856404;
            padding: 12px;
            border-radius: 10px;
            text-align: center;
            margin-bottom: 20px;
            font-weight: 500;
        }
        .area-upload {
            border: 3px dashed #1e3c72;
            border-radius: 15px;
            padding: 30px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 20px;
        }
        .area-upload:hover {
            background-color: #f8f9ff;
        }
        input[type="file"] {
            display: none;
        }
        /* ✅ BOTÃO ESTILIZADO */
        .btn-selecionar {
            background: #1e3c72;
            color: white;
            padding: 12px 25px;
            border-radius: 8px;
            display: inline-block;
            cursor: pointer;
            font-weight: bold;
            margin-top: 10px;
            transition: background 0.3s;
        }
        .btn-selecionar:hover {
            background: #2a5298;
        }
        .preview-fotos {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            margin-bottom: 20px;
        }
        .foto-mini {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #ddd;
        }
        .configuracao {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 20px;
        }
        .linha-config {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        .valor-velocidade {
            background: #1e3c72;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            min-width: 70px;
            text-align: center;
            font-weight: bold;
        }
        input[type="range"] {
            width: 60%;
        }
        .btn-criar {
            width: 100%;
            padding: 15px;
            background: linear-gradient(90deg, #28a745, #20c997);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
        }
        .btn-criar:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
        .progresso-container {
            width: 100%;
            height: 25px;
            background-color: #e9ecef;
            border-radius: 15px;
            overflow: hidden;
            margin: 15px auto;
            display: none;
        }
        .barra-progresso {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #1e3c72, #2a5298);
            color: white;
            font-weight: bold;
            text-align: center;
            line-height: 25px;
            transition: width 0.3s;
        }
        .area-resultado {
            text-align: center;
            margin-top: 20px;
            display: none;
        }
        #gifFinal {
            max-width: 100%;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .btn-baixar {
            display: inline-block;
            margin-top: 15px;
            padding: 12px 30px;
            background: #ffc107;
            color: #333;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
        }
        .espaco-anuncio {
            width: 100%;
            height: 90px;
            background-color: #e9ecef;
            border: 1px solid #ccc;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 20px 0;
            color: #6c757d;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🖼️ Criador de GIF</h1>
        <p class="subtitulo">Transforme suas fotos em animação!</p>

        <div class="aviso">
            ⚠️ Dica: Use fotos de até <strong>2MB ou 3MB</strong> para ficar rápido!
        </div>

        <div class="espaco-anuncio">
            Espaço Publicitário
        </div>

        <!-- ✅ ÁREA COM O BOTÃO VISÍVEL -->
        <div class="area-upload">
            <p>📷 Clique no botão abaixo para selecionar suas fotos</p>
            <label for="arquivos" class="btn-selecionar">📂 ABRIR FOTOS</label>
            <input type="file" id="arquivos" accept="image/*" multiple>
        </div>

        <div class="preview-fotos" id="preview"></div>

        <div class="configuracao">
            <div class="linha-config">
                <label>⏱️ Velocidade:</label>
                <div class="valor-velocidade" id="mostrarVelocidade">0.5s</div>
            </div>
            <input type="range" id="velocidade" min="100" max="1500" value="500">
        </div>

        <button class="btn-criar" id="btnCriar" disabled>
            🎬 Criar GIF
        </button>

        <div class="progresso-container" id="containerProgresso">
            <div class="barra-progresso" id="barraProgresso">0%</div>
        </div>

        <div class="area-resultado" id="resultado">
            <h3>✅ Pronto!</h3>
            <img id="gifFinal" src="" alt="GIF">
            <a href="#" id="btnBaixar" class="btn-baixar" download="meu-gif.gif">📥 BAIXAR</a>
        </div>

        <div class="espaco-anuncio">
            Espaço Publicitário
        </div>

    </div>

    <!-- BIBLIOTECA EMBUTIDA -->
    <script>
        !function(){function t(e){if(n[32])throw Error("GIF.js already loaded");n[32]=!0;var t=function(){function t(){}return function(n,r){function o(){for(var t=[],n=0;n<r.length;n++)t[n]=r[n];return t}function i(t){return"[object Array]"===Object.prototype.toString.call(t)}function a(t){return"[object Object]"===Object.prototype.toString.call(t)}function s(t){return"function"==typeof t}function c(t){return"number"==typeof t}function u(t){return"string"==typeof t}function f(t){return null!=t}function l(t){return void 0!==t}function p(){return t.prototype.constructor=t}function d(){return n}function h(){return r}function v(){return o()}function y(){return p(),d()}return{super:y,init:d,args:h,select:v,extend:function(t){var n=Object.create(t.prototype);return n.constructor=this,this.prototype=n,n},create:function(t){var n=Object.create(t.prototype);return n.constructor=this,this.prototype=n},proto:t.prototype}}();return t}();var n={},e=t(n);e.prototype={constructor:e},e.prototype.init=function(){var t=this,n=t.proto,r={};return n.forEach(function(n){r[n]=t[n]}),r},e.prototype.on=function(t,n){var r=this.e=this.e||{};return(r[t]=r[t]||[]).push(n),this},e.prototype.off=function(t,n){var r=this.e=this.e||{};return r[t]&&r[t].splice(r[t].indexOf(n),1),this},e.prototype.trigger=function(t){var n,r,e=this.e=this.e||{},i=Array.prototype.slice.call(arguments,1);return e[t]&&(n=e[t].slice(),r=0,e=r<n.length?n[r]:void 0,n.length>0&&n.forEach.call(n,function(n){return n.apply(this,i)},this)),this}};var n=function(){function t(){this._super.apply(this,arguments)}var n=e.extend(t);return n.prototype.init=function(){var t=this;return t._super(),t.o={},t},n.prototype.addFrame=function(t,n){var r=this.o;return r.frames=r.frames||[],r.frames.push({image:t,options:n}),this},n.prototype.getFrames=function(){return this.o.frames},n.prototype.render=function(){var t=this,n=t.o,r=t.getFrames(),i=n.width||320,a=n.height||240,s=n.quality||10,c=n.workers||2,u=n.dither||!1,f=n.globalPalette