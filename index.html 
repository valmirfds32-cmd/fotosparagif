    <script>
        let imagens = [];
        const input = document.getElementById('arquivos');
        const preview = document.getElementById('preview');
        const btnCriar = document.getElementById('btnCriar');
        const velocidade = document.getElementById('velocidade');
        const mostrarVel = document.getElementById('mostrarVelocidade');
        const containerProgresso = document.getElementById('containerProgresso');
        const barraProgresso = document.getElementById('barraProgresso');
        const resultado = document.getElementById('resultado');
        const gifFinal = document.getElementById('gifFinal');
        const btnBaixar = document.getElementById('btnBaixar');

        mostrarVel.textContent = (velocidade.value/1000).toFixed(1) + 's';
        velocidade.addEventListener('input', () => {
            mostrarVel.textContent = (velocidade.value/1000).toFixed(1) + 's';
        });

        input.addEventListener('change', (e) => {
            const arquivos = Array.from(e.target.files);
            imagens = [];
            preview.innerHTML = "";
            
            arquivos.forEach(arq => {
                const leitor = new FileReader();
                leitor.onload = function(ev) {
                    const img = new Image();
                    img.src = ev.target.result;
                    imagens.push(img);
                    
                    const mini = document.createElement('img');
                    mini.src = ev.target.result;
                    mini.className = "foto-mini";
                    preview.appendChild(mini);
                }
                leitor.readAsDataURL(arq);
            });
            
            btnCriar.disabled = false;
        });

        btnCriar.addEventListener('click', () => {
            if(imagens.length < 2) {
                alert("Selecione pelo menos 2 fotos!");
                return;
            }

            containerProgresso.style.display = "block";
            barraProgresso.style.width = "0%";
            barraProgresso.textContent = "0%";
            resultado.style.display = "none";

            const gif = new GIF({
                workers: 1,
                quality: 10,
                width: 400,
                height: 400,
                workerScript: ''
            });

            imagens.forEach(img => {
                gif.addFrame(img, {delay: velocidade.value});
            });

            gif.on('progress', function(p) {
                const porcentagem = Math.round(p * 100);
                barraProgresso.style.width = porcentagem + "%";
                barraProgresso.textContent = porcentagem + "%";
            });

            gif.on('finished', function(blob) {
                const url = URL.createObjectURL(blob);
                gifFinal.src = url;
                btnBaixar.href = url;
                
                containerProgresso.style.display = "none";
                resultado.style.display = "block";
            });

            gif.render();
        });
    </script>
</body>
</html>
